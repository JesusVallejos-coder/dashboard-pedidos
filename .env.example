# ==============================================================
# CONFIGURACIÓN DE BASE DE DATOS
# Copiar este archivo como .env y completar con los valores reales
# ==============================================================

# Cadena de conexión completa (formato: mssql+pymssql://usuario:password@servidor/base_de_datos)
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_HOST=tu_servidor
DB_NAME=tu_base_de_datos

# ==============================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ==============================================================
FLASK_PORT=5000
FLASK_DEBUG=False

# Intervalo de actualización del hilo de fondo (en segundos)
BACKGROUND_CHECK_INTERVAL=20

# Límite máximo de pedidos a mostrar
MAX_PEDIDOS=200
MAX_PEDIDOS_POR_COLUMNA=10
